# Database
DATABASE_URL=postgres://routewerk:password@localhost:5432/routewerk?sslmode=disable

# Auth
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h

# Server
PORT=8080
ENV=development

# Image Storage (S3-compatible)
STORAGE_ENDPOINT=
STORAGE_BUCKET=routewerk-images
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CREDENTIALS_FILE=

# Fly.io
FLY_APP_NAME=routewerk
FLY_REGION=iad
