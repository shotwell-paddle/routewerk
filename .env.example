# Database
DATABASE_URL=postgres://routewerk:password@localhost:5432/routewerk?sslmode=disable
# Opt-in to automatic recovery from a dirty migration state at startup.
# Default false: a dirty database refuses to start and an operator must run
# `admin migrate-force N` after inspecting the schema.
#ALLOW_DIRTY_MIGRATION_FORCE=false

# Auth
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h
SESSION_SECRET=change-me-to-a-different-random-string-32-chars

# Server
PORT=8080
ENV=development
FRONTEND_URL=http://localhost:8080

# Image Storage (S3-compatible)
STORAGE_ENDPOINT=
STORAGE_BUCKET=routewerk-images
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CREDENTIALS_FILE=

# Email (SMTP) — transactional email delivery. Optional in dev: if unset,
# emails are logged to stdout instead of sent. In production, leaving these
# unset is a hard error for any email that is actually attempted, and is
# rejected at startup when MAGIC_LINK_ENABLED=true. Works with any SMTP
# provider (Postmark, Resend, SES, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Passwordless magic-link sign-in. Default off — password is the primary
# auth path. Turn this on ONLY after SMTP is configured above; production
# refuses to boot with MAGIC_LINK_ENABLED=true and no SMTP_HOST/SMTP_FROM,
# so magic links can never be silently dropped.
MAGIC_LINK_ENABLED=false

# Fly.io
FLY_APP_NAME=routewerk
FLY_REGION=ord
